{
    "name": "carrotbot",
    "version": "1.0.0",
    "description": "bot send and receive message and execute command",
    "keywords": [
        "bot",
        "wechat"
    ],
    "license": "Apache-2.0",
    "author": "mcxiaoke@github.com",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "build": "tsc && node -e \"require('fs').cpSync('src/templates','dist/router/templates',{recursive:true})\"",
        "start": "node --env-file=.env dist/index.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier:fix": "prettier --write .",
        "check": "npm run lint && npm run build"
    },
    "dependencies": {
        "@fastify/multipart": "^9.4.0",
        "@wecom/aibot-node-sdk": "^1.0.4",
        "axios": "^1.8.3",
        "better-sqlite3": "^11.9.1",
        "dayjs": "^1.11.20",
        "dotenv": "^17.3.1",
        "fastify": "^5.2.0",
        "https-proxy-agent": "^8.0.0",
        "node-telegram-bot-api": "^0.67.0",
        "socks-proxy-agent": "^9.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.12",
        "@types/eslint": "^9.6.1",
        "@types/node": "^22.13.10",
        "@types/node-telegram-bot-api": "^0.64.14",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.57.2"
    }
}