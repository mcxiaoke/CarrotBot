{
    "arrowParens": "always",
    "bracketSpacing": true,
    "insertPragma": false,
    "printWidth": 100,
    "proseWrap": "always",
    "quoteProps": "as-needed",
    "semi": false,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "none",
    "useTabs": false,
    "bracketSameLine": false,
    "endOfLine": "lf"
}
